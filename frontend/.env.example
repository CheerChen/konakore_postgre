# API target for the Vite dev-server proxy (`/api` -> target).
# Points at the konakore API container exposed on the pi host.
# Copy this file to .env and adjust if needed.
#
# On pi the stack maps the api container's :3000 to host :3001
# (see docker-compose.yaml: ports "3001:3000").
VITE_API_TARGET=http://192.168.0.110:3001
